---
import { ClientRouter } from "astro:transitions";
import OceanBackground from "../components/OceanBackground.svelte";

interface Props {
	title?: string;
}

const { title = "Portafolio" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<link rel="icon" href="/favicon.svg" />
		<script
			is:inline
			src="https://rybbit.asprino.dev/api/script.js"
			data-site-id="ad088843ac0c"
			defer></script>
		<script
			is:inline
			defer
			src="https://umami.asprino.dev/script.js"
			data-website-id="50baaba3-915b-4f01-8e78-e8b7805486e5"></script>
		<ClientRouter />
	</head>
	<body>
		<OceanBackground client:only="svelte" transition:persist />
		<div class="overlay">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		background: #000;
		min-height: 100vh;
		overflow-x: hidden;
	}
</style>

<style>
	.overlay {
		position: relative;
		z-index: 1;
		min-height: 100vh;
	}
</style>
