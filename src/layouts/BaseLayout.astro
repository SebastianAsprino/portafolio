---
import OceanBackground from '../components/OceanBackground.svelte';

interface Props {
	title?: string;
}

const { title = 'Portafolio' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<link rel="icon" href="/favicon.svg" />
	</head>
	<body>
		<OceanBackground client:only="svelte" />
		<div class="overlay">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		background: #000;
		min-height: 100vh;
		overflow-x: hidden;
	}
</style>

<style>
	.overlay {
		position: relative;
		z-index: 1;
		min-height: 100vh;
	}
</style>
