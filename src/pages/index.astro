---
import BentoLayout from "../layouts/BentoLayout.astro";
import ProjectCard from "../components/ProjectCard.svelte";
import portfolio from "../data/portfolio.json";
import cv from "../data/cv.json";
import { buildIconMap } from "../lib/stack-icons";

const allTechs = [...new Set(portfolio.projects.flatMap((p) => p.stack))];
const icons = buildIconMap(allTechs);
---

<BentoLayout title="Sebastian Asprino" activeSection="inicio">
	<section class="summary">
		<span class="label">sobre mí</span>
		<p>{cv.summary.intro}</p>
		<p class="stack-line">{cv.summary.stack}</p>
	</section>

	<div class="projects-grid">
		{
			portfolio.projects.map((p) => (
				<ProjectCard project={p} icons={icons} client:visible />
			))
		}
	</div>
</BentoLayout>

<style>
	.summary {
		background: rgba(0, 10, 30, 0.72);
		border: 1px solid rgba(130, 200, 255, 0.18);
		backdrop-filter: blur(2px);
		padding: 0.85rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		margin-bottom: 6px;
	}

	.label {
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(130, 200, 255, 0.5);
		font-family: monospace;
	}

	.summary p {
		font-family: monospace;
		font-size: 0.78rem;
		color: rgba(200, 232, 248, 0.75);
		line-height: 1.6;
		margin: 0;
	}

	.stack-line {
		color: rgba(200, 232, 248, 0.42) !important;
		font-size: 0.7rem !important;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6px;
	}

	@media (max-width: 640px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
