---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sebastian Asprino">
	<div class="site-center">
		<div class="bento">
			<header class="block block--header">
				<span class="name">Sebastian Asprino</span>
			</header>

			<div class="block block--top">
				<span class="tagline">Software Engineer</span>
			</div>

			<nav class="block block--nav">
				<div class="nav-wide">
					<ul>
						<li><a href="#about">About</a></li>
						<li><a href="#projects">Projects</a></li>
						<li><a href="#stack">Stack</a></li>
						<li><a href="#contact">Contact</a></li>
					</ul>
				</div>
				<details class="nav-narrow">
					<summary>Menu</summary>
					<ul>
						<li><a href="#about">About</a></li>
						<li><a href="#projects">Projects</a></li>
						<li><a href="#stack">Stack</a></li>
						<li><a href="#contact">Contact</a></li>
					</ul>
				</details>
			</nav>

			<main class="block--main">
				<section class="block" id="about">
					<h2>About</h2>
					<p>placeholder</p>
				</section>

				<div class="posts-horizontal">
					<section class="block" id="projects">
						<h2>Projects</h2>
						<p>placeholder</p>
					</section>
					<section class="block" id="stack">
						<h2>Stack</h2>
						<p>placeholder</p>
					</section>
				</div>

				<section class="block" id="contact">
					<h2>Contact</h2>
					<p>placeholder</p>
				</section>
			</main>

			<footer class="block block--footer">
				<span>Built with Astro · 2026</span>
			</footer>
		</div>
	</div>
</BaseLayout>

<style>
	.site-center {
		height: 100vh;
		display: flex;
		justify-content: center;
		align-items: center;
		padding: 1rem;
	}

	.bento {
		display: grid;
		width: 100%;
		max-width: 900px;
		height: 90vh;
		grid-template-columns: 180px 1fr;
		grid-template-rows: auto 1fr auto;
		grid-template-areas:
			"header  top"
			"nav     main"
			"footer  footer";
		gap: 6px;
	}

	.block {
		background: rgba(0, 10, 30, 0.72);
		border: 1px solid rgba(130, 200, 255, 0.18);
		backdrop-filter: blur(2px);
		padding: 1rem;
		color: #c8e8f8;
		font-family: monospace;
	}

	.block--header {
		grid-area: header;
	}
	.block--top {
		grid-area: top;
	}
	.block--nav {
		grid-area: nav;
	}
	.block--footer {
		grid-area: footer;
	}

	.block--main {
		grid-area: main;
		display: flex;
		flex-direction: column;
		gap: 6px;
		overflow-y: auto;
		scrollbar-width: none;
	}

	.block--main::-webkit-scrollbar {
		display: none;
	}

	.posts-horizontal {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6px;
	}

	h2 {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(130, 200, 255, 0.6);
		margin-bottom: 0.5rem;
	}

	.name {
		font-size: 1.1rem;
		font-weight: bold;
		letter-spacing: 0.05em;
	}

	.tagline {
		font-size: 0.85rem;
		color: rgba(200, 232, 248, 0.7);
	}

	nav ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	nav a {
		color: #c8e8f8;
		text-decoration: none;
		font-size: 0.85rem;
		opacity: 0.8;
	}

	nav a:hover {
		opacity: 1;
	}

	.block--footer {
		text-align: center;
		font-size: 0.75rem;
		opacity: 0.5;
	}

	.nav-wide {
		display: block;
	}
	.nav-narrow {
		display: none;
	}

	@media (max-width: 640px) {
		.bento {
			grid-template-columns: 1fr;
			grid-template-areas:
				"header"
				"top"
				"nav"
				"main"
				"footer";
		}

		.posts-horizontal {
			grid-template-columns: 1fr;
		}

		.nav-wide {
			display: none;
		}
		.nav-narrow {
			display: block;
		}

		details.nav-narrow > ul {
			margin-top: 0.5rem;
		}
	}
</style>
